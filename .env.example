# App
APP_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_KEY_PEPPER=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-long-random-jwt-secret

# PostgreSQL and Redis
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/saasdb
REDIS_URL=redis://redis:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_WITH_PRO_PRICE_ID
STRIPE_PRICE_ENTERPRISE=price_REPLACE_WITH_ENTERPRISE_PRICE_ID
STRIPE_TEST_MODE=true

# Runtime flags
DISABLE_RATE_LIMIT=false
USAGE_LOG_INLINE=false

# Frontend build
VITE_API_URL=http://localhost:8000

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# AWS / production deploy
AWS_REGION=ap-south-1
ECR_REGISTRY=123456789.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=latest
EC2_HOST=YOUR_EC2_HOST
